# =============================================================================
# NodeSH Example - Environment Variables
# =============================================================================
# Copy this file to .env and update the values as needed
# All databases below are pre-configured for Docker Compose services
# Run: docker-compose up -d
# =============================================================================

# =============================================================================
# MongoDB - Document Database
# =============================================================================
MONGODB_URI=mongodb://localhost:27017/nodesh_example
# Alternative: MONGO_URL=mongodb://localhost:27017/nodesh_example

# =============================================================================
# Redis - In-Memory Cache
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=          # Optional: Set if Redis requires auth
# REDIS_DB=0               # Optional: Redis database number (0-15)
# REDIS_URL=redis://localhost:6379  # Alternative: Use connection string

# =============================================================================
# PostgreSQL - Relational Database
# =============================================================================
PGHOST=localhost
PGPORT=5432
PGDATABASE=nodesh_example
PGUSER=postgres
PGPASSWORD=postgres
# PGSSL=false              # Set to 'true' for SSL connections

# Alternative: Use connection string instead of individual vars
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nodesh_example

# =============================================================================
# MySQL - Relational Database
# =============================================================================
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=nodesh_example
MYSQL_USER=root
MYSQL_PASSWORD=mysql
# MYSQL_URL=mysql://root:mysql@localhost:3306/nodesh_example

# Alternative: Use connection string instead of individual vars
# DATABASE_URL=mysql://root:mysql@localhost:3306/nodesh_example

# =============================================================================
# Neo4j - Graph Database
# =============================================================================
NEO4J_URI=bolt://localhost:7687
NEO4J_HOST=localhost
NEO4J_PORT=7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
# NEO4J_SCHEME=bolt        # Options: bolt, neo4j, bolt+s, neo4j+s
# NEO4J_ENCRYPTED=false    # Set to 'true' for encrypted connections

# =============================================================================
# DynamoDB - AWS NoSQL Database (Local Development)
# =============================================================================
# For local development with DynamoDB Local
DYNAMODB_LOCAL=true
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_PORT=8000
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local
AWS_SESSION_TOKEN=
DYNAMODB_TABLE_PREFIX=

# For production AWS DynamoDB, comment out DYNAMODB_LOCAL and DYNAMODB_ENDPOINT
# and set these:
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SESSION_TOKEN=your-session-token  # Optional: for temporary credentials

# =============================================================================
# Prisma ORM (Optional - if using Prisma)
# =============================================================================
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/nodesh_example

# =============================================================================
# Next.js Configuration
# =============================================================================
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NODE_ENV=development
