{
  "name": "node-console-example-nestjs",
  "version": "1.0.0",
  "description": "NestJS example with multi-database support (MongoDB, PostgreSQL, MySQL, Redis, Neo4j, DynamoDB) for node-console",
  "scripts": {
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "console": "node-console",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "db:setup": "node scripts/setup-databases.js"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.750.0",
    "@aws-sdk/lib-dynamodb": "^3.750.0",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/bullmq": "^11.0.2",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/mongoose": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "axios": "^1.8.0",
    "bcryptjs": "^3.0.0",
    "bullmq": "^5.41.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "ioredis": "^5.5.0",
    "mongoose": "^8.10.0",
    "mysql2": "^3.12.0",
    "neo4j-driver": "^5.28.0",
    "pg": "^8.13.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.0"
  },
  "overrides": {
    "path-to-regexp": "^8.2.0",
    "picomatch": "^4.0.2",
    "ajv": "^8.17.1"
  }
}
