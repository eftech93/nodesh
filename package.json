{
  "name": "@eftech93/nodesh",
  "version": "0.0.2",
  "description": "Interactive shell for Node.js applications (Express, NestJS, etc.) with autocompletion",
  "keywords": [
    "nodejs",
    "express",
    "nestjs",
    "console",
    "repl",
    "shell",
    "terminal",
    "cli",
    "interactive",
    "autocomplete",
    "active-record",
    "typescript",
    "mongodb",
    "redis",
    "bullmq"
  ],
  "homepage": "https://github.com/eftech93/nodesh#readme",
  "bugs": {
    "url": "https://github.com/eftech93/nodesh/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eftech93/nodesh.git"
  },
  "license": "MIT",
  "author": "EFTECH93",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nodesh": "dist/cli.js",
    "nsh": "dist/cli.js",
    "eft": "dist/cli.js"
  },
  "directories": {
    "example": "example",
    "test": "tests"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:report": "node scripts/generate-test-report.js",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm test && npm publish --access public",
    "release:patch": "npm version patch && npm run release",
    "release:minor": "npm version minor && npm run release",
    "release:major": "npm version major && npm run release",
    "link:global": "npm link",
    "link:example": "cd example && npm link @eftech93/nodesh",
    "link:example-nextjs": "cd example-nextjs && npm link @eftech93/nodesh",
    "link:example-nestjs": "cd example-nestjs && npm link @eftech93/nodesh",
    "relink": "npm run build && npm run link:global && npm run link:example && npm run link:example-nextjs && npm run link:example-nestjs",
    "relink:nextjs": "npm run build && npm run link:global && cd example-nextjs && npm link @eftech93/nodesh",
    "relink:nestjs": "npm run build && npm run link:global && cd example-nestjs && npm link @eftech93/nodesh",
    "relink:force": "npm run build && npm run link:global && cd example && rm -rf node_modules/@eftech93 && npm link @eftech93/nodesh && cd ../example-nextjs && rm -rf node_modules/@eftech93 && npm link @eftech93/nodesh",
    "test:integration": "bash scripts/run-integration-tests.sh",
    "test:integration:nextjs": "bash scripts/run-integration-tests.sh nextjs",
    "test:integration:nestjs": "bash scripts/run-integration-tests.sh nestjs",
    "test:integration:express": "bash scripts/run-integration-tests.sh express",
    "test:integration:autocomplete": "bash scripts/run-integration-tests.sh autocomplete",
    "test:integration:quick": "cross-env ENABLE_INTEGRATION_TESTS=true npx jest tests/integration --verbose --runInBand --no-watchman --forceExit",
    "test:integration:ci": "cross-env ENABLE_INTEGRATION_TESTS=true npx jest tests/integration --runInBand --no-watchman --forceExit",
    "test:docker:up": "docker-compose -f docker-compose.test.yml up -d",
    "test:docker:down": "docker-compose -f docker-compose.test.yml down --volumes",
    "test:docker:logs": "docker-compose -f docker-compose.test.yml logs -f"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^9.4.1",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "jest": "^29.0.0",
    "next": "^16.2.1",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "xml2js": "^0.6.2"
  },
  "peerDependencies": {
    "@nestjs/common": "^8.0.0 || ^9.0.0 || ^10.0.0",
    "@nestjs/core": "^8.0.0 || ^9.0.0 || ^10.0.0",
    "express": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
