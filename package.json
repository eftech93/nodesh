{
  "name": "@eftech93/nodesh",
  "version": "0.0.1",
  "description": "Rails-like interactive shell for Node.js applications (Express, NestJS, etc.) with autocompletion",
  "keywords": [
    "nodejs",
    "express",
    "nestjs",
    "console",
    "repl",
    "shell",
    "terminal",
    "rails",
    "cli",
    "interactive",
    "autocomplete",
    "active-record",
    "typescript",
    "mongodb",
    "redis",
    "bullmq"
  ],
  "homepage": "https://github.com/eftech93/nodesh#readme",
  "bugs": {
    "url": "https://github.com/eftech93/nodesh/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eftech93/nodesh.git"
  },
  "license": "MIT",
  "author": "EFTECH93",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nodesh": "dist/cli.js",
    "nsh": "dist/cli.js",
    "eft": "dist/cli.js"
  },
  "directories": {
    "example": "example",
    "test": "tests"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm test && npm publish --access public",
    "release:patch": "npm version patch && npm run release",
    "release:minor": "npm version minor && npm run release",
    "release:major": "npm version major && npm run release"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^9.4.1"
  },
  "devDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "express": "^4.18.2",
    "jest": "^29.0.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^8.0.0 || ^9.0.0 || ^10.0.0",
    "@nestjs/core": "^8.0.0 || ^9.0.0 || ^10.0.0",
    "express": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "@nestjs/common": {
      "optional": true
    },
    "@nestjs/core": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=14.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
