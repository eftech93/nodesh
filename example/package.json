{
  "name": "node-console-example-express",
  "version": "1.0.0",
  "description": "Express example with MongoDB, Redis, and BullMQ for node-console",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "console": "node-console",
    "dev": "nodemon src/app.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "ioredis": "^5.3.0",
    "bullmq": "^5.0.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "nodemon": "^3.0.0"
  },
  "nodeConsole": {
    "appEntry": "src/app.js",
    "prompt": "express> "
  }
}
